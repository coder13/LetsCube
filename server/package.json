{
  "name": "letscube-server",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "6.0.0",
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^4.22.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "getconfig": "^4.5.0",
    "ioredis": "^5.8.2",
    "letscube-scrambles": "0.1.0",
    "lodash": "^4.17.21",
    "lusca": "^1.7.0",
    "mongodb": "^7.5.0",
    "mongoose": "^8.24.1",
    "morgan": "^1.11.0",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "passport-local": "^1.0.0",
    "passport-oauth2": "^1.8.0",
    "passport-wca": "^1.0.3",
    "pg": "8.22.0",
    "prisma": "7.8.0",
    "rest-api-errors": "^1.2.1",
    "socket.io": "^4.8.3",
    "socket.io-adapter": "^2.5.8",
    "uuid": "^11.1.1",
    "winston": "3.2.1"
  },
  "scripts": {
    "start:server": "nodemon index.js",
    "start:socket": "nodemon socket/",
    "lint": "eslint ./",
    "lint:fix": "eslint --fix ./",
    "postgres:migrate": "prisma migrate deploy --config prisma.config.mjs",
    "postgres:migrate:dev": "prisma migrate dev --config prisma.config.mjs",
    "postgres:migrate:status": "prisma migrate status --config prisma.config.mjs",
    "postgres:schema:check": "prisma migrate diff --exit-code --from-config-datasource --to-schema prisma/schema.prisma --config prisma.config.mjs",
    "postgres:schema:validate": "prisma validate --config prisma.config.mjs",
    "privacy:purge-user-emails": "node privacy/purgeUserEmails.js",
    "usernames:backfill": "node ../scripts/backfill-normalized-usernames.js",
    "test": "jest --passWithNoTests",
    "test:ci": "yarn test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "kill-port": "1.6.0",
    "nodemon": "3.1.14"
  }
}
