{
  "name": "letscube-server",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "6.0.0",
    "connect-mongo": "^3.2.0",
    "cors": "^2.8.5",
    "express": "^4.22.2",
    "express-session": "^1.19.0",
    "express-socket.io-session": "^1.3.5",
    "getconfig": "^4.5.0",
    "ioredis": "^5.8.2",
    "lodash": "^4.17.21",
    "mongoose": "^6.13.9",
    "morgan": "^1.11.0",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "passport-local": "^1.0.0",
    "passport-oauth2": "^1.8.0",
    "passport-wca": "^1.0.3",
    "pg": "8.22.0",
    "prisma": "7.8.0",
    "rest-api-errors": "^1.2.1",
    "scrambow": "^1.8.1",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.1",
    "winston": "3.2.1"
  },
  "scripts": {
    "start:server": "nodemon index.js",
    "start:socket": "nodemon socket/",
    "lint": "eslint ./",
    "lint:fix": "eslint --fix ./",
    "postgres:migrate": "prisma migrate deploy --config prisma.config.mjs",
    "postgres:migrate:dev": "prisma migrate dev --config prisma.config.mjs",
    "postgres:migrate:status": "prisma migrate status --config prisma.config.mjs",
    "postgres:schema:check": "prisma migrate diff --exit-code --from-config-datasource --to-schema prisma/schema.prisma --config prisma.config.mjs",
    "postgres:schema:validate": "prisma validate --config prisma.config.mjs",
    "test": "jest --passWithNoTests",
    "test:ci": "yarn test"
  },
  "devDependencies": {
    "eslint": "6.8.0",
    "eslint-config-airbnb": "18.1.0",
    "eslint-config-airbnb-base": "14.1.0",
    "eslint-plugin-import": "2.20.2",
    "husky": "4.2.5",
    "jest": "^26.6.0",
    "jest-resolve": "^26.6.2",
    "jest-watch-typeahead": "^0.6.1",
    "kill-port": "1.6.0",
    "nodemon": "2.0.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn lint"
    }
  }
}
