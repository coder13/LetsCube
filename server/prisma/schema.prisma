datasource db {
  provider = "postgresql"
  schemas  = ["analytics", "app"]
}

model User {
  id                 String            @id @db.Uuid
  wcaUserId          BigInt            @unique(map: "users_wca_user_id_key") @map("wca_user_id")
  /// Compatibility-only during the privacy cutover. This column must remain null.
  email              String?
  name               String
  username           String?
  usernameNormalized String?           @unique(map: "users_username_normalized_key") @map("username_normalized")
  wcaId              String?           @map("wca_id")
  preferences        Json              @default("{}") @db.JsonB
  avatar             Json              @default("{}") @db.JsonB
  sourceCreatedAt    DateTime?         @map("source_created_at") @db.Timestamptz(6)
  sourceUpdatedAt    DateTime          @map("source_updated_at") @db.Timestamptz(6)
  ingestedAt         DateTime          @default(now()) @map("ingested_at") @db.Timestamptz(6)
  ownedRooms         Room[]            @relation("RoomOwner")
  administeredRooms  Room[]            @relation("RoomAdmin")
  roomParticipations RoomParticipant[]
  sessionParticipations SessionParticipant[]
  solves             Solve[]
  friendshipsAsLow   FriendRelationship[] @relation("FriendshipLowUser")
  friendshipsAsHigh  FriendRelationship[] @relation("FriendshipHighUser")
  requestsMade       FriendRelationship[] @relation("FriendshipRequester")
  blocksMade         UserBlock[]          @relation("Blocker")
  blocksReceived     UserBlock[]          @relation("Blocked")

  @@map("users")
  @@schema("app")
}

model SocialNotification {
  id                 String   @id @db.Uuid
  mongoId            String   @unique(map: "social_notifications_mongo_id_key") @map("mongo_id")
  recipientWcaUserId BigInt   @map("recipient_wca_user_id")
  actorWcaUserId     BigInt   @map("actor_wca_user_id")
  type               String
  sourceType         String   @map("source_type")
  sourceId           String   @map("source_id")
  dedupeKey          String   @unique(map: "social_notifications_dedupe_key_key") @map("dedupe_key")
  readAt             DateTime? @map("read_at") @db.Timestamptz(6)
  expiresAt          DateTime @map("expires_at") @db.Timestamptz(6)
  sourceCreatedAt    DateTime? @map("source_created_at") @db.Timestamptz(6)
  sourceUpdatedAt    DateTime @map("source_updated_at") @db.Timestamptz(6)
  ingestedAt         DateTime @default(now()) @map("ingested_at") @db.Timestamptz(6)

  @@index([recipientWcaUserId, readAt, sourceCreatedAt(sort: Desc), mongoId(sort: Desc)], map: "social_notifications_recipient_read_created_idx")
  @@index([expiresAt], map: "social_notifications_expiry_idx")
  @@map("social_notifications")
  @@schema("app")
}

model FriendRelationship {
  id                String    @id @db.Uuid
  pairKey           String    @unique(map: "friend_relationships_pair_key_key") @map("pair_key")
  lowUserId         String    @map("low_user_id") @db.Uuid
  highUserId        String    @map("high_user_id") @db.Uuid
  status            String
  requestedByUserId String?   @map("requested_by_user_id") @db.Uuid
  cooldownUntil     DateTime? @map("cooldown_until") @db.Timestamptz(6)
  revision          Int
  stateChangedAt    DateTime  @map("state_changed_at") @db.Timestamptz(6)
  sourceCreatedAt   DateTime? @map("source_created_at") @db.Timestamptz(6)
  sourceUpdatedAt   DateTime  @map("source_updated_at") @db.Timestamptz(6)
  ingestedAt        DateTime  @default(now()) @map("ingested_at") @db.Timestamptz(6)
  lowUser           User      @relation("FriendshipLowUser", fields: [lowUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  highUser          User      @relation("FriendshipHighUser", fields: [highUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  requestedBy       User?     @relation("FriendshipRequester", fields: [requestedByUserId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([lowUserId, status], map: "friend_relationships_low_status_idx")
  @@index([highUserId, status], map: "friend_relationships_high_status_idx")
  @@index([requestedByUserId, status], map: "friend_relationships_requester_status_idx")
  @@map("friend_relationships")
  @@schema("app")
}

model UserBlock {
  id              String    @id @db.Uuid
  blockerId       String    @map("blocker_id") @db.Uuid
  blockedId       String    @map("blocked_id") @db.Uuid
  pairKey         String    @map("pair_key")
  active          Boolean
  revision        Int
  stateChangedAt  DateTime  @map("state_changed_at") @db.Timestamptz(6)
  sourceCreatedAt DateTime? @map("source_created_at") @db.Timestamptz(6)
  sourceUpdatedAt DateTime  @map("source_updated_at") @db.Timestamptz(6)
  ingestedAt      DateTime  @default(now()) @map("ingested_at") @db.Timestamptz(6)
  blocker         User      @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  blocked         User      @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([blockerId, blockedId], map: "user_blocks_blocker_blocked_key")
  @@index([blockedId], map: "user_blocks_blocked_idx")
  @@index([pairKey], map: "user_blocks_pair_key_idx")
  @@map("user_blocks")
  @@schema("app")
}

model Room {
  id                      String            @id @db.Uuid
  mongoId                 String            @unique(map: "rooms_mongo_id_key") @map("mongo_id")
  name                    String
  cubeEvent               String            @map("cube_event")
  accessCode              String            @unique(map: "rooms_access_code_key") @map("access_code")
  passwordHash            String?           @map("password_hash")
  roomType                String            @map("room_type")
  ownerId                 String?           @map("owner_id") @db.Uuid
  adminId                 String?           @map("admin_id") @db.Uuid
  requireRevealedIdentity Boolean           @default(false) @map("require_revealed_identity")
  startTime               DateTime?         @map("start_time") @db.Timestamptz(6)
  started                 Boolean           @default(false)
  nextSolveAt             DateTime?         @map("next_solve_at") @db.Timestamptz(6)
  expiresAt               DateTime?         @map("expires_at") @db.Timestamptz(6)
  twitchChannel           String?           @map("twitch_channel")
  deletedAt               DateTime?         @map("deleted_at") @db.Timestamptz(6)
  sourceCreatedAt         DateTime?         @map("source_created_at") @db.Timestamptz(6)
  sourceUpdatedAt         DateTime          @map("source_updated_at") @db.Timestamptz(6)
  ingestedAt              DateTime          @default(now()) @map("ingested_at") @db.Timestamptz(6)
  owner                   User?             @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  admin                   User?             @relation("RoomAdmin", fields: [adminId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  participants            RoomParticipant[]
  attempts                Attempt[]
  solves                  Solve[]
  raceSessions            RaceSession[]
  kind                    String            @default("normal")
  competitionRef          String?           @map("competition_ref")

  @@map("rooms")
  @@schema("app")
}

model RaceSession {
  id                    String               @id @db.Uuid
  roomId                String               @map("room_id") @db.Uuid
  cubeEvent             String               @map("cube_event")
  raceFormat            String               @map("race_format")
  scrambleSource        String               @map("scramble_source")
  status                String
  scheduledStartAt      DateTime?            @map("scheduled_start_at") @db.Timestamptz(6)
  startedAt             DateTime?            @map("started_at") @db.Timestamptz(6)
  endedAt               DateTime?            @map("ended_at") @db.Timestamptz(6)
  currentAttemptOrdinal Int?                 @map("current_attempt_ordinal")
  nextSolveAt           DateTime?            @map("next_solve_at") @db.Timestamptz(6)
  sourceKey             String               @unique(map: "race_sessions_source_key_key") @map("source_key")
  sourceCreatedAt       DateTime?            @map("source_created_at") @db.Timestamptz(6)
  sourceUpdatedAt       DateTime             @map("source_updated_at") @db.Timestamptz(6)
  ingestedAt            DateTime             @default(now()) @map("ingested_at") @db.Timestamptz(6)
  room                  Room                 @relation(fields: [roomId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  participants          SessionParticipant[]
  attempts              Attempt[]

  @@unique([id, roomId], map: "race_sessions_id_room_id_key")
  @@index([roomId, status, sourceUpdatedAt(sort: Desc)], map: "race_sessions_room_status_idx")
  @@map("race_sessions")
  @@schema("app")
}

model SessionParticipant {
  raceSessionId   String      @map("race_session_id") @db.Uuid
  userId          String      @map("user_id") @db.Uuid
  eligible        Boolean     @default(true)
  competing       Boolean     @default(false)
  waitingFor      Boolean     @default(false) @map("waiting_for")
  registered      Boolean     @default(false)
  sourceUpdatedAt DateTime    @map("source_updated_at") @db.Timestamptz(6)
  ingestedAt      DateTime    @default(now()) @map("ingested_at") @db.Timestamptz(6)
  raceSession     RaceSession @relation(fields: [raceSessionId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  user            User        @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@id([raceSessionId, userId])
  @@map("session_participants")
  @@schema("app")
}

model RoomParticipant {
  roomId          String   @map("room_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  competing       Boolean  @default(false)
  waitingFor      Boolean  @default(false) @map("waiting_for")
  banned          Boolean  @default(false)
  inRoom          Boolean  @default(false) @map("in_room")
  registered      Boolean  @default(false)
  sourceUpdatedAt DateTime @map("source_updated_at") @db.Timestamptz(6)
  ingestedAt      DateTime @default(now()) @map("ingested_at") @db.Timestamptz(6)
  room            Room     @relation(fields: [roomId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([roomId, userId])
  @@map("room_participants")
  @@schema("app")
}

model Attempt {
  id              String    @id @db.Uuid
  mongoId         String    @unique(map: "attempts_mongo_id_unique") @map("mongo_id")
  roomId          String    @map("room_id") @db.Uuid
  raceSessionId   String?   @map("race_session_id") @db.Uuid
  ordinal         Int
  cubeEvent       String    @map("cube_event")
  scrambles       Json      @db.JsonB
  sourceCreatedAt DateTime? @map("source_created_at") @db.Timestamptz(6)
  sourceUpdatedAt DateTime  @map("source_updated_at") @db.Timestamptz(6)
  ingestedAt      DateTime  @default(now()) @map("ingested_at") @db.Timestamptz(6)
  room            Room      @relation(fields: [roomId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  raceSession     RaceSession? @relation(fields: [raceSessionId, roomId], references: [id, roomId], onDelete: Restrict, onUpdate: NoAction)
  solves          Solve[]

  @@index([roomId, ordinal], map: "attempts_room_ordinal_idx")
  @@index([raceSessionId, ordinal, id], map: "attempts_race_session_ordinal_idx")
  @@unique([id, roomId], map: "attempts_id_room_id_key")
  @@map("attempts")
  @@schema("app")
}

model Solve {
  id                String   @id @db.Uuid
  attemptId         String   @map("attempt_id") @db.Uuid
  roomId            String   @map("room_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  timeMs            Int      @map("time_ms")
  dnf               Boolean  @default(false)
  plusTwoPenalty    Boolean  @default(false) @map("plus_two_penalty")
  inspectionPenalty Boolean  @default(false) @map("inspection_penalty")
  aufPenalty        Boolean  @default(false) @map("auf_penalty")
  submissionId      String?  @map("submission_id")
  sourceCreatedAt   DateTime @map("source_created_at") @db.Timestamptz(6)
  sourceUpdatedAt   DateTime @map("source_updated_at") @db.Timestamptz(6)
  ingestedAt        DateTime @default(now()) @map("ingested_at") @db.Timestamptz(6)
  attempt           Attempt  @relation(fields: [attemptId, roomId], references: [id, roomId], onDelete: Restrict, onUpdate: NoAction)
  room              Room     @relation(fields: [roomId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([attemptId, userId], map: "solves_attempt_id_user_id_key")
  @@index([userId, sourceCreatedAt(sort: Desc), id(sort: Desc)], map: "solves_user_created_idx")
  @@index([userId, sourceCreatedAt(sort: Desc), id(sort: Desc), attemptId], map: "solves_user_session_history_idx")
  @@map("solves")
  @@schema("app")
}

model MetricEvent {
  id         String   @id @db.Uuid
  eventName  String   @map("event_name")
  occurredAt DateTime @map("occurred_at") @db.Timestamptz(6)
  actorId    String?  @map("actor_id")
  roomId     String?  @map("room_id")
  properties Json     @default("{}") @db.JsonB
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  ingestedAt DateTime @default(now()) @map("ingested_at") @db.Timestamptz(6)

  @@index([eventName, occurredAt(sort: Desc)], map: "analytics_events_name_time_idx")
  @@index([roomId, occurredAt(sort: Desc)], map: "analytics_events_room_time_idx")
  @@index([expiresAt], map: "analytics_events_expiry_idx")
  @@map("events")
  @@schema("analytics")
}
